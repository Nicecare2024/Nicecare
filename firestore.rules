rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(resourceData) {
      return isSignedIn() && resourceData.ownerUid == request.auth.uid;
    }

    // User profile document - only owner can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null 
                         && request.auth.uid == userId;
    }

    // Customers collection: each document must have ownerUid set to the user's UID
    match /customers/{docId} {
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow read: if isOwner(resource.data);
      allow update, delete: if isOwner(resource.data);
    }
    
    // Block all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
